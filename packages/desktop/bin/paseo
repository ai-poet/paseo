#!/bin/sh
set -eu

SCRIPT_PATH=$0
case "$SCRIPT_PATH" in
  /*) ;;
  *) SCRIPT_PATH="$(pwd)/$SCRIPT_PATH" ;;
esac

# Follow symlinks so `/usr/local/bin/paseo` resolves back into the app bundle.
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
  LINK_TARGET=$(readlink "$SCRIPT_PATH")
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="${SCRIPT_DIR}/${LINK_TARGET}" ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
RESOURCES_DIR=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)

# macOS: MacOS/<AppName> is a sibling of Resources/
# Linux: the executable sits next to resources/
MACOS_DIR="${RESOURCES_DIR}/../MacOS"
LINUX_DIR="${RESOURCES_DIR}/.."
EXECUTABLE_NAME_FILE="${RESOURCES_DIR}/bin/app-executable-name"
EXECUTABLE_NAME=""
if [ -f "$EXECUTABLE_NAME_FILE" ]; then
  EXECUTABLE_NAME=$(sed -n '1p' "$EXECUTABLE_NAME_FILE")
fi

if [ -n "$EXECUTABLE_NAME" ] && [ -x "${MACOS_DIR}/${EXECUTABLE_NAME}" ]; then
  APP_EXECUTABLE="${MACOS_DIR}/${EXECUTABLE_NAME}"
elif [ -n "$EXECUTABLE_NAME" ] && [ -x "${LINUX_DIR}/${EXECUTABLE_NAME}" ]; then
  APP_EXECUTABLE="${LINUX_DIR}/${EXECUTABLE_NAME}"
elif [ -d "$MACOS_DIR" ]; then
  APP_EXECUTABLE=$(find "$MACOS_DIR" -maxdepth 1 -type f -perm -111 -print | sort | head -n 1)
elif [ -d "$LINUX_DIR" ]; then
  APP_EXECUTABLE=$(find "$LINUX_DIR" -maxdepth 1 -type f -perm -111 ! -name "*.bin" -print | sort | head -n 1)
else
  APP_EXECUTABLE=""
fi

if [ -z "$APP_EXECUTABLE" ] || [ ! -x "$APP_EXECUTABLE" ]; then
  echo "Bundled app executable not found relative to ${RESOURCES_DIR}" >&2
  exit 1
fi

RUNNER_PATH="${RESOURCES_DIR}/app.asar.unpacked/dist/daemon/node-entrypoint-runner.js"
CLI_ENTRYPOINT="${RESOURCES_DIR}/app.asar/node_modules/@getpaseo/cli/dist/index.js"

exec env ELECTRON_RUN_AS_NODE=1 "${APP_EXECUTABLE}" --disable-warning=DEP0040 "${RUNNER_PATH}" node-script "${CLI_ENTRYPOINT}" "$@"
